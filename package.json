{
  "name": "software-testing-assignment",
  "version": "1.0.0",
  "description": "Testing environment for assignment with Mocha, Chai, NYC, and Coveralls",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "mocha --require @babel/register test/**/*.test.js",
    "coverage": "nyc --reporter=lcov --reporter=text --require @babel/register --exclude 'src/.internal/**' mocha test/**/*.test.js",
    "coveralls": "nyc report --reporter=text-lcov | coveralls"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/register": "^7.25.0",
    "chai": "^6.2.2",
    "coveralls": "^3.1.1",
    "mocha": "^11.7.5",
    "nyc": "^18.0.0"
  }
}
